# Database Configuration for PostgreSQL (Neon)
DATABASE_URL=postgresql://username:password@host:5432/dbname?channel_binding=require&sslmode=require
DIRECT_URL=postgresql://username:password@host:5432/dbname?sslmode=require

# NextAuth Configuration
NEXTAUTH_SECRET=your-nextauth-secret-key-min-32-chars
NEXTAUTH_URL=https://your-production-domain.vercel.app

# Optional: Neon Project Information
NEON_PROJECT_ID=your-neon-project-id

# Optional: Vercel Analytics
VERCEL_WEB_ANALYTICS_ID=your-vercel-analytics-id
