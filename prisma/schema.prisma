generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  ADMIN_KLINIK
  DOKTER
  CUSTOMER
}

enum AppointmentStatus {
  WAITING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum PetHotelBookingStatus {
  BOOKED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum PetHotelRoomStatus {
  AVAILABLE
  RESERVED
  OCCUPIED
  MAINTENANCE
  INACTIVE
}

enum PetHotelLogType {
  FEEDING
  MEDICINE
  NOTE
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  RETURN
  DAMAGED
  EXPIRED
  CORRECTION
  OPNAME
}

enum ProductStatus {
  ACTIVE
  ARCHIVED
}

enum InvoiceStatus {
  UNPAID
  PARTIAL_PAYMENT
  PAID
  CANCELLED
}

enum InvoiceItemType {
  KONSULTASI
  TINDAKAN
  OBAT
  PET_HOTEL
  PRODUK
}

enum PaymentMethod {
  CASH
  NON_CASH
}

enum MedicalRecordStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CLOSED
}

model User {
  id                String    @id @default(cuid())
  username          String    @unique
  pinHash           String
  name              String
  phone             String?
  role              UserRole
  isActive          Boolean   @default(true)
  isLocked          Boolean   @default(false)
  mustChangePin     Boolean   @default(true)
  failedPinAttempts Int       @default(0)
  lockedUntil       DateTime?
  createdById       String?
  createdAt         DateTime  @default(now())

  createdBy              User?           @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers           User[]          @relation("UserCreatedBy")
  customer               Customer?
  notifications          Notification[]
  auditLogs              AuditLog[]
  appointmentsAsDoctor   Appointment[]   @relation("DoctorAppointments")
  medicalRecordsAsDoctor MedicalRecord[] @relation("DoctorMedicalRecords")
}

model Customer {
  id               String  @id @default(cuid())
  userId           String? @unique
  name             String
  isGuest          Boolean @default(false)
  phone            String?
  email            String?
  address          String?
  emergencyContact String?
  photo            String?
  notes            String?

  user           User?           @relation(fields: [userId], references: [id])
  pets           Pet[]
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  invoices       Invoice[]

  @@unique([name, isGuest])
  @@index([isGuest])
}

model Pet {
  id         String    @id @default(cuid())
  customerId String
  name       String
  species    String
  breed      String?
  birthDate  DateTime?
  gender     String?
  photo      String?

  customer       Customer           @relation(fields: [customerId], references: [id])
  weightLogs     PetWeightLog[]
  vaccineRecords PetVaccineRecord[]
  diseaseRecords PetDiseaseRecord[]
  allergies      PetAllergy[]
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  hotelBookings  PetHotelBooking[]

  @@index([customerId])
}

model PetWeightLog {
  id     String   @id @default(cuid())
  petId  String
  weight Float
  date   DateTime @default(now())

  pet Pet @relation(fields: [petId], references: [id])
}

model PetVaccineRecord {
  id          String    @id @default(cuid())
  petId       String
  vaccineName String
  date        DateTime  @default(now())
  nextDueDate DateTime?

  pet Pet @relation(fields: [petId], references: [id])
}

model PetDiseaseRecord {
  id          String   @id @default(cuid())
  petId       String
  diseaseName String
  note        String?
  date        DateTime @default(now())

  pet Pet @relation(fields: [petId], references: [id])
}

model PetAllergy {
  id       String  @id @default(cuid())
  petId    String
  allergen String
  note     String?

  pet Pet @relation(fields: [petId], references: [id])
}

model Appointment {
  id                  String            @id @default(cuid())
  petId               String
  customerId          String
  doctorId            String?
  date                DateTime
  queueNumber         Int?
  status              AppointmentStatus @default(WAITING)
  requestedByCustomer Boolean           @default(false)

  pet           Pet            @relation(fields: [petId], references: [id])
  customer      Customer       @relation(fields: [customerId], references: [id])
  doctor        User?          @relation("DoctorAppointments", fields: [doctorId], references: [id])
  medicalRecord MedicalRecord?

  @@index([customerId, date])
  @@index([doctorId, status, date])
  @@index([status, date])
}

model MedicalRecord {
  id              String                 @id @default(cuid())
  recordNumber    String                 @unique
  appointmentId   String                 @unique
  customerId      String
  petId           String
  doctorId        String
  date            DateTime               @default(now())
  chiefComplaint  String?
  history         String?
  physicalExam    String?
  vitalSigns      String?
  weight          Float?
  temperature     Float?
  heartRate       Int?
  respiratoryRate Int?
  diagnosis       String?
  treatment       String?
  prescription    String?
  labResult       String?
  notes           String?
  attachments     String?
  status          MedicalRecordStatus    @default(OPEN)
  version         Int                    @default(1)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  customer    Customer    @relation(fields: [customerId], references: [id])
  pet         Pet         @relation(fields: [petId], references: [id])
  doctor      User        @relation("DoctorMedicalRecords", fields: [doctorId], references: [id])

  @@index([customerId, date])
  @@index([petId, date])
  @@index([doctorId, date])
}

model PetHotelBooking {
  id                  String                @id @default(cuid())
  bookingNumber       String?               @unique
  petId               String
  roomId              String?
  checkInDate         DateTime
  checkOutDate        DateTime
  actualCheckInAt     DateTime?
  actualCheckOutAt    DateTime?
  status              PetHotelBookingStatus @default(BOOKED)
  requestedByCustomer Boolean               @default(false)
  notes               String?

  pet          Pet           @relation(fields: [petId], references: [id])
  room         PetHotelRoom? @relation(fields: [roomId], references: [id])
  logs         PetHotelLog[]
  invoiceItems InvoiceItem[]

  @@index([status, checkInDate, checkOutDate])
  @@index([roomId, checkInDate, checkOutDate])
}

model PetHotelRoom {
  id                String             @id @default(cuid())
  name              String
  roomNumber        String?
  roomType          String             @default("STANDARD")
  pricePerNight     Float              @default(100000)
  capacity          Int                @default(1)
  status            PetHotelRoomStatus @default(AVAILABLE)
  cleaningStatus    String             @default("CLEAN")
  maintenanceStatus String             @default("OPERATIONAL")

  bookings PetHotelBooking[]

  @@index([status])
}

model PetHotelLog {
  id          String          @id @default(cuid())
  bookingId   String
  type        PetHotelLogType
  description String
  photo       String?
  date        DateTime        @default(now())

  booking PetHotelBooking @relation(fields: [bookingId], references: [id])
}

model Product {
  id          String        @id @default(cuid())
  name        String
  sku         String?
  barcode     String?
  brand       String?
  description String?
  categoryId  String?
  supplierId  String?
  unit        String?
  buyPrice    Float         @default(0)
  sellPrice   Float         @default(0)
  costPrice   Float         @default(0)
  stock       Int           @default(0)
  minStock    Int           @default(0)
  maxStock    Int?
  status      ProductStatus @default(ACTIVE)
  imageUrl    String?
  isArchived  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  category       ProductCategory? @relation(fields: [categoryId], references: [id])
  supplier       Supplier?        @relation(fields: [supplierId], references: [id])
  stockMovements StockMovement[]
  invoiceItems   InvoiceItem[]

  @@index([categoryId])
  @@index([supplierId])
  @@index([isArchived])
}

model Procedure {
  id          String   @id @default(cuid())
  code        String?  @unique
  name        String
  description String?
  price       Float    @default(0)
  createdAt   DateTime @default(now())

  invoiceItems InvoiceItem[]
}

model ProductCategory {
  id   String @id @default(cuid())
  name String

  products Product[]
}

model Supplier {
  id      String  @id @default(cuid())
  name    String
  contact String?

  products Product[]
}

model StockMovement {
  id        String            @id @default(cuid())
  productId String
  type      StockMovementType
  quantity  Int
  note      String?
  date      DateTime          @default(now())

  product Product @relation(fields: [productId], references: [id])
}

model Invoice {
  id              String        @id @default(cuid())
  customerId      String
  appointmentId   String?
  medicalRecordId String?
  petId           String?
  doctorId        String?
  createdById     String?
  invoiceNumber   String        @unique
  walkInName      String?
  status          InvoiceStatus @default(UNPAID)
  subtotal        Float         @default(0)
  discountAmount  Float         @default(0)
  taxRate         Float         @default(0)
  taxAmount       Float         @default(0)
  totalAmount     Float         @default(0)
  notes           String?
  date            DateTime      @default(now())

  customer Customer      @relation(fields: [customerId], references: [id])
  items    InvoiceItem[]
  payments Payment[]

  @@index([customerId, status])
  @@index([date])
}

model InvoiceItem {
  id                String          @id @default(cuid())
  invoiceId         String
  productId         String?
  procedureId       String?
  petHotelBookingId String?
  type              InvoiceItemType
  description       String
  qty               Int             @default(1)
  price             Float           @default(0)
  subtotal          Float           @default(0)
  createdAt         DateTime        @default(now())

  invoice         Invoice          @relation(fields: [invoiceId], references: [id])
  product         Product?         @relation(fields: [productId], references: [id])
  procedure       Procedure?       @relation(fields: [procedureId], references: [id])
  petHotelBooking PetHotelBooking? @relation(fields: [petHotelBookingId], references: [id])
}

model Payment {
  id        String        @id @default(cuid())
  invoiceId String
  method    PaymentMethod
  amount    Float
  date      DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}

model Notification {
  id      String   @id @default(cuid())
  userId  String
  title   String
  message String
  isRead  Boolean  @default(false)
  type    String?
  date    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entity      String
  entityId    String?
  description String?
  date        DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, date])
}

model Settings {
  id                  String   @id @default(cuid())
  clinicName          String?
  logo                String?
  address             String?
  phone               String?
  email               String?
  website             String?
  taxNumber           String?
  operationalHours    String?
  timezone            String?
  currency            String?
  language            String?
  footerInfo          String?
  receiptHeader       String?
  receiptFooter       String?
  appName             String?
  appVersion          String?
  dateFormat          String?
  timeFormat          String?
  numberFormat        String?
  pagination          Int?
  sessionTimeout      Int?
  autoLogout          Boolean? @default(false)
  defaultDashboard    String?
  appointmentDuration Int?
  workingDays         String?
  holidayRules        String?
  invoicePrefix       String?
  medicalRecordPrefix String?
  customerPrefix      String?
  petPrefix           String?
  posPrefix           String?
  bookingPrefix       String?
  receiptPrefix       String?
  autoNumbering       Boolean? @default(true)
  theme               String?
}
